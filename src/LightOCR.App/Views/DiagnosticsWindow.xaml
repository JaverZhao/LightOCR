<Window x:Class="LightOCR.App.Views.DiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="诊断信息" Height="450" Width="500"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <ScrollViewer>
        <StackPanel Margin="16">
            <TextBlock FontSize="16" FontWeight="Bold" Margin="0,0,0,12">诊断信息</TextBlock>

            <GroupBox Header="应用" Margin="0,0,0,8">
                <StackPanel>
                    <Label Content="{Binding AppVersion}" />
                    <Label Content="{Binding NativeApiVersion}" />
                    <Label Content="{Binding OcrEngineState}" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="系统" Margin="0,0,0,8">
                <StackPanel>
                    <Label Content="{Binding OsVersion}" />
                    <Label Content="{Binding CpuArchitecture}" />
                    <Label Content="{Binding DpiMode}" />
                    <Label Content="{Binding Screens}" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="模型" Margin="0,0,0,8">
                <StackPanel>
                    <Label Content="{Binding DetModel}" />
                    <Label Content="{Binding RecModel}" />
                    <Label Content="{Binding ModelDir}" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="依赖" Margin="0,0,0,8">
                <StackPanel>
                    <Label Content="{Binding OnnxRuntimeVersion}" />
                    <Label Content="{Binding NativeLibPath}" />
                </StackPanel>
            </GroupBox>

            <Button Content="打开日志目录" Command="{Binding OpenLogDirCommand}"
                    Padding="16,6" Margin="0,8" HorizontalAlignment="Left" />
        </StackPanel>
    </ScrollViewer>
</Window>
