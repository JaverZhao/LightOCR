<Window x:Class="LightOCR.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LightOCR" Height="720" Width="1100"
        MinHeight="580" MinWidth="840"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True" Drop="OnDrop" DragOver="OnDragOver">
    <Grid Margin="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="2,0,2,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="LightOCR" FontSize="25" FontWeight="SemiBold" />
                <TextBlock Text="本地识别，图片不会离开你的电脑" Margin="0,4,0,0"
                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
            </StackPanel>
            <Border Grid.Column="1" Background="#E4ECE8" CornerRadius="6" Padding="10,6"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="7" Height="7" Fill="{StaticResource AccentBrush}"
                             Margin="0,0,7,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ModelState}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="打开图片" Command="{Binding OpenImageCommand}" Margin="0,0,8,0" />
            <Button Grid.Column="1" Content="粘贴图片" Command="{Binding PasteImageCommand}" Margin="0,0,8,0" />
            <Button Grid.Column="2" Content="截图识别" Command="{Binding ScreenshotCommand}"
                    Style="{StaticResource PrimaryButton}" />
            <Border Grid.Column="4" Background="{StaticResource HairlineBrush}" Margin="0,7" />
            <Button Grid.Column="6" Content="重新识别" Command="{Binding ReRecognizeCommand}"
                    Style="{StaticResource QuietButton}" Margin="0,0,2,0" />
            <Button Grid.Column="7" Content="复制结果" Command="{Binding CopyResultCommand}"
                    Style="{StaticResource QuietButton}" />
            <Button Grid.Column="9" Content="诊断" Command="{Binding OpenDiagnosticsCommand}"
                    Style="{StaticResource QuietButton}" Margin="0,0,2,0" />
            <Button Grid.Column="10" Content="设置" Command="{Binding OpenSettingsCommand}"
                    Style="{StaticResource QuietButton}" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="46*" MinWidth="300" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="54*" MinWidth="360" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorder}" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="18,15,18,12">
                        <TextBlock Text="图片预览" Style="{StaticResource SectionLabel}" />
                        <TextBlock Text="{Binding CurrentImage.SourceName}" HorizontalAlignment="Right"
                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis" MaxWidth="230" />
                    </Grid>
                    <Border Grid.Row="1" Margin="12,0,12,12" Background="#E9EDEA" CornerRadius="8">
                        <Grid>
                            <Image Source="{Binding ImagePreview}" Stretch="Uniform"
                                   Margin="12" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ImagePreview}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="250">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ImagePreview}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <Border Width="48" Height="48" CornerRadius="12" Background="#DCE5E0"
                                        HorizontalAlignment="Center" Margin="0,0,0,14">
                                    <TextBlock Text="＋" FontSize="24" Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="打开、粘贴或拖入一张图片" FontSize="15" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="也可以点击“截图识别”框选屏幕内容" Margin="0,7,0,0"
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           TextAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="12" Background="Transparent"
                          HorizontalAlignment="Stretch" ResizeBehavior="PreviousAndNext"
                          Cursor="SizeWE" />

            <Border Grid.Column="2" Style="{StaticResource PanelBorder}" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Margin="18,15,18,12">
                        <TextBlock Text="识别文本" Style="{StaticResource SectionLabel}" />
                        <TextBlock Text="{Binding OcrElapsed}" HorizontalAlignment="Right"
                                   FontFamily="Consolas" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </Grid>
                    <Grid Grid.Row="1" Margin="12,0,12,8">
                        <TextBox Text="{Binding OcrResultText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                 Padding="7,5" FontSize="15"
                                 Background="Transparent" BorderThickness="0" IsReadOnly="False"
                                 SelectionBrush="{StaticResource AccentBrush}" />
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasResult}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="识别结果会显示在这里" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="完成后会自动复制到剪贴板" Margin="0,7,0,0" FontSize="12"
                                       Foreground="#8A9490" HorizontalAlignment="Center" />
                        </StackPanel>
                        <Border Background="#E8F0EC" CornerRadius="8" Padding="18,12"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="正在识别" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Text="…" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="4,0,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    <Border Grid.Row="2" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,1,0,0"
                            Padding="18,10">
                        <TextBlock Text="可直接编辑识别文本，Ctrl+A 全选" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="3" Margin="2,13,2,0">
            <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
            <TextBlock Text="PP-OCRv6 · 本地 CPU" HorizontalAlignment="Right" FontSize="11"
                       Foreground="#8A9490" />
        </Grid>
    </Grid>
</Window>
