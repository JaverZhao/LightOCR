<Window x:Class="LightOCR.App.Views.CaptureOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        Topmost="True"
        Cursor="Cross" Focusable="True">
    <Canvas x:Name="OverlayCanvas" Background="Transparent">
        <Rectangle x:Name="DimmingRect" Fill="#66000000" />
        <Rectangle x:Name="SelectionRect"
                   Stroke="#7DD3C0" StrokeThickness="2"
                   Fill="#18FFFFFF" Visibility="Collapsed" />
        <TextBlock x:Name="SizeText" Foreground="White"
                   Background="#D918201E" Padding="7,4"
                   FontSize="12" Visibility="Collapsed" />
    </Canvas>
</Window>
