<Window x:Class="LightOCR.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="580" Width="520"
        MinWidth="480" MinHeight="400"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="2,0,2,18">
            <TextBlock Text="设置" FontSize="25" FontWeight="SemiBold" />
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="0,0,8,0">
            <StackPanel>
                <Border Style="{StaticResource PanelBorder}" Padding="0" Margin="0,0,0,14">
                    <StackPanel Margin="0,0,0,4">
                        <TextBlock Text="快捷键" Style="{StaticResource SectionLabel}" Margin="18,15,18,0" />
                        <Border Height="1" Background="{StaticResource HairlineBrush}" Margin="0,10,0,0" />
                        <StackPanel Margin="18,14,18,18">
                            <TextBlock Text="截图识别快捷键" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                            <TextBox Text="{Binding HotkeyText, Mode=OneWay}"
                                     IsReadOnly="True" Padding="8,6" FontSize="14"
                                     Background="{StaticResource PanelMutedBrush}"
                                     BorderBrush="{StaticResource HairlineBrush}"
                                     BorderThickness="1" Cursor="Hand"
                                     PreviewMouseDown="HotkeyBox_OnPreviewMouseDown" />
                            <TextBlock Text="{Binding HotkeyStatus}"
                                       FontSize="11" Foreground="{StaticResource AccentBrush}" Margin="0,6,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorder}" Padding="0" Margin="0,0,0,14">
                    <StackPanel Margin="0,0,0,4">
                        <TextBlock Text="OCR" Style="{StaticResource SectionLabel}" Margin="18,15,18,0" />
                        <Border Height="1" Background="{StaticResource HairlineBrush}" Margin="0,10,0,0" />
                        <StackPanel Margin="18,14,18,18" Grid.IsSharedSizeScope="True">
                            <CheckBox Content="自动复制识别结果" IsChecked="{Binding AutoCopy}"
                                      FontSize="14" Margin="0,0,0,10" />
                            <CheckBox Content="识别完成后显示结果窗口" IsChecked="{Binding ShowResultWindow}"
                                      FontSize="14" Margin="0,0,0,14" />

                            <Grid Margin="0,4,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="置信度阈值" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Column="1" Minimum="0" Maximum="1" TickFrequency="0.05"
                                        Value="{Binding ConfidenceThreshold}"
                                        Margin="12,0" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding ConfidenceThreshold, StringFormat=F2}"
                                           FontSize="13" FontFamily="Consolas"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" Width="36" TextAlignment="Right" />
                            </Grid>

                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="CPU 线程数" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Column="1" Minimum="1" Maximum="16" TickFrequency="1"
                                        Value="{Binding CpuThreads}" IsSnapToTickEnabled="True"
                                        Margin="12,0" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding CpuThreads}"
                                           FontSize="13" FontFamily="Consolas"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" Width="36" TextAlignment="Right" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorder}" Padding="0" Margin="0,0,0,14">
                    <StackPanel Margin="0,0,0,4">
                        <TextBlock Text="应用" Style="{StaticResource SectionLabel}" Margin="18,15,18,0" />
                        <Border Height="1" Background="{StaticResource HairlineBrush}" Margin="0,10,0,0" />
                        <StackPanel Margin="18,14,18,18">
                            <CheckBox Content="开机启动" IsChecked="{Binding StartWithWindows}"
                                      FontSize="14" Margin="0,0,0,10" />
                            <CheckBox Content="启动后最小化到托盘" IsChecked="{Binding StartMinimized}"
                                      FontSize="14" Margin="0,0,0,10" />
                            <CheckBox Content="保存识别历史" IsChecked="{Binding SaveHistory}"
                                      FontSize="14" Margin="0,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Rectangle Height="18" Fill="Transparent" />
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,1,0,0"
                Margin="-24,12,-24,-16" Padding="24,14,24,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="恢复默认" Command="{Binding ResetCommand}"
                        Style="{StaticResource QuietButton}" Margin="0,0,6,0" />
                <Button Content="应用" Command="{Binding ApplyCommand}"
                        Style="{StaticResource PrimaryButton}" Margin="0,0,6,0" />
                <Button Content="关闭" Command="{Binding CloseCommand}"
                        Style="{StaticResource QuietButton}" Margin="0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
